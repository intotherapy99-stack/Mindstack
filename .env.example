# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
NODE_ENV=development

# Database (Supabase)
DATABASE_URL=postgresql://postgres:password@localhost:5432/mindstack
DIRECT_URL=postgresql://postgres:password@localhost:5432/mindstack

# Auth (NextAuth)
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=generate-with-openssl-rand-base64-32
AUTH_SECRET=generate-with-openssl-rand-base64-32

# Cloudinary (file uploads)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Razorpay (payments)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
NEXT_PUBLIC_RAZORPAY_KEY_ID=

# MSG91 (WhatsApp/SMS - India)
MSG91_AUTH_KEY=
MSG91_SENDER_ID=MNDSCK
MSG91_TEMPLATE_ID_REMINDER_24H=
MSG91_TEMPLATE_ID_REMINDER_2H=
MSG91_TEMPLATE_ID_BOOKING_CONFIRMED=

# Resend (email)
RESEND_API_KEY=
EMAIL_FROM=notifications@mindstack.in

# Redis (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# PostHog (analytics)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com

# Sentry (error tracking)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron Security — required for /api/cron/* endpoints
# Generate with: openssl rand -base64 32
CRON_SECRET=

# Admin
ADMIN_EMAIL=admin@mindstack.in
